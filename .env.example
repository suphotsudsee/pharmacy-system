# ===========================================
# Pharmacy System - Environment Variables
# ระบบคลังยาสำหรับโรงพยาบาล
# ===========================================

# Database Configuration
# การเชื่อมต่อฐานข้อมูล
# - SQLite: file:./dev.db (ค่า default สำหรับ development)
# - LibSQL: libsql://your-database.turso.io
# - PostgreSQL: postgresql://user:password@host:port/database
DATABASE_URL="file:./dev.db"

# NextAuth.js Secret
# ใช้สำหรับเข้ารหัส session และ JWT tokens
# สร้างด้วยคำสั่ง: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-change-this-in-production"

# Application Environment
# NODE_ENV: development | production | test
NODE_ENV="development"

# Server Port (Optional)
# ถ้าไม่กำหนดจะใช้ค่า default ของ Next.js (3000)
PORT="9401"

# ================================
# Optional Configurations
# ================================

# NextAuth URL (สำหรับ production)
# NEXTAUTH_URL="https://your-domain.com"

# Log Level (debug, info, warn, error)
# LOG_LEVEL="info"